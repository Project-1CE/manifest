<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <!-- Remotes -->
  <remote  name="custom"
           fetch="https://github.com/Project-1CE"
           revision="lineage-18.1" />

  <remote  name="custom-priv"
           fetch="ssh://git@github.com/Project-1CE"
           revision="lineage-18.1" />

  <remote  name="gitlab"
           fetch="https://gitlab.com"/>

  <!-- Replace existing repositories -->
  <remove-project name="LineageOS/android" />
  <project path="android" name="manifest" remote="custom" />
  <remove-project name="LineageOS/android_art" />
  <project path="art" name="art" remote="custom" />
  <remove-project name="LineageOS/android_bionic" />
  <project path="bionic" name="bionic" remote="custom" />
  <remove-project name="LineageOS/android_build_soong" />
  <project path="build/soong" name="build_soong" remote="custom" >
    <linkfile src="root.bp" dest="Android.bp" />
    <linkfile src="bootstrap.bash" dest="bootstrap.bash" />
  </project>
  <remove-project name="platform/external/arm-optimized-routines" />
  <project path="external/arm-optimized-routines" name="external_arm-optimized-routines" remote="custom" />
  <remove-project name="platform/external/libfuse" />
  <project path="external/libfuse" name="external_libfuse" remote="custom" />
  <remove-project name="LineageOS/android_external_openssh" />
  <project path="external/openssh" name="external_openssh" remote="custom" />
  <remove-project name="platform/external/sqlite" />
  <project path="external/sqlite" name="external_sqlite" remote="custom" />
  <remove-project name="LineageOS/android_frameworks_base" />
  <project path="frameworks/base" name="frameworks_base" remote="custom" />
  <remove-project name="LineageOS/android_frameworks_native" />
  <project path="frameworks/native" name="frameworks_native" remote="custom" />
  <remove-project name="platform/libcore" />
  <project path="libcore" name="libcore" remote="custom" />
  <remove-project name="platform/prebuilts/abi-dumps/vndk" />
  <project path="prebuilts/abi-dumps/vndk" name="prebuilts_abi-dumps_vndk" remote="custom" />
  <remove-project name="LineageOS/android_system_core" />
  <project path="system/core" name="system_core" remote="custom" />
  <remove-project name="platform/system/security" />
  <project path="system/security" name="system_security" remote="custom" />
  <remove-project name="LineageOS/android_vendor_lineage" />
  <project path="vendor/lineage" name="vendor_lineage" remote="custom" />

  <!-- Add new repositories -->

  <!-- External repositories -->
  <project name="ProtonAOSP/android_vendor_gapps" path="vendor/gapps" remote="gitlab" revision="rvc" />

</manifest>
